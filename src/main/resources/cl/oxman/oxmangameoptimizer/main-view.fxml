<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="cl.oxman.oxmangameoptimizer.ui.MainController"
        alignment="TOP_CENTER"
        spacing="12">

    <padding>
        <Insets top="25"
                right="30"
                bottom="25"
                left="30"/>
    </padding>

    <!-- ===================================== -->
    <!-- TÍTULO -->
    <!-- ===================================== -->

    <Label
            text="OXMAN IT"
            styleClass="title"/>

    <Label
            text="GAME OPTIMIZER"
            styleClass="title2"/>

    <Label
            text="Performance Dashboard"
            styleClass="subtitle"/>

    <Label
            text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            styleClass="separator"/>

    <!-- ===================================== -->
    <!-- CPU -->
    <!-- ===================================== -->

    <Label
            text="🖥 CPU"
            styleClass="section"/>

    <ProgressBar
            fx:id="cpuBar"
            prefWidth="340"/>

    <Label
            fx:id="cpuLabel"
            text="CPU: 0%"/>

    <Label
            fx:id="cpuNameLabel"
            text="Procesador"
            wrapText="true"
            styleClass="hardware-info"/>

    <Label
            fx:id="cpuCoresLabel"
            text="Núcleos"
            wrapText="true"
            styleClass="hardware-info"/>

    <Label
            fx:id="cpuFreqLabel"
            text="Frecuencia"
            wrapText="true"
            styleClass="hardware-info"/>

    <Label
            text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            styleClass="separator"/>

    <!-- ===================================== -->
    <!-- RAM -->
    <!-- ===================================== -->

    <Label
            text="💾 RAM"
            styleClass="section"/>

    <ProgressBar
            fx:id="ramBar"
            prefWidth="340"/>

    <Label
            fx:id="ramLabel"
            text="RAM: 0%"/>

    <Label
            text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            styleClass="separator"/>

    <!-- ===================================== -->
    <!-- HARDWARE -->
    <!-- ===================================== -->

    <Label
            text="🎮 GPU"
            styleClass="section"/>

    <Label
            fx:id="gpuLabel"
            text="Detectando GPU..."
            wrapText="true"
            styleClass="hardware-info"/>

    <Label
            text="💽 Disco"
            styleClass="section"/>

    <Label
            fx:id="diskLabel"
            text="Detectando Disco..."
            wrapText="true"
            styleClass="hardware-info"/>

    <Label
            text="🪟 Sistema Operativo"
            styleClass="section"/>

    <Label
            fx:id="osLabel"
            text="Detectando Sistema..."
            wrapText="true"
            styleClass="hardware-info"/>

    <Label
            text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            styleClass="separator"/>

    <!-- ===================================== -->
    <!-- ESTADO -->
    <!-- ===================================== -->

    <Label
            fx:id="statusLabel"
            text="🟢 Sistema Óptimo"
            styleClass="status"/>

    <!-- ===================================== -->
    <!-- BOTÓN -->
    <!-- ===================================== -->

    <Button
            text="🚀 BOOST FPS"
            prefWidth="250"
            prefHeight="48"
            onAction="#boostFPS"/>

    <Label
            text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            styleClass="separator"/>

    <!-- ===================================== -->
    <!-- LOG -->
    <!-- ===================================== -->

    <Label
            text="📜 Registro de Optimización"
            styleClass="section"/>

    <TextArea
            fx:id="logArea"
            prefWidth="340"
            prefHeight="170"
            editable="false"
            wrapText="true"
            styleClass="log-area"/>

</VBox>